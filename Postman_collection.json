{
  "info": {
    "name": "Jong Tov Cafe API",
    "_postman_id": "6f2f9d4a-0000-4c3b-9f4a-000000000000",
    "description": "Collection for local development against the backend\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"pass123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  var json = pm.response.json();",
                  "  if (json && json.token) {",
                  "    pm.environment.set('token', json.token);",
                  "    console.log('Saved token to environment');",
                  "  }",
                  "} catch (e) { console.log('No JSON response'); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"pass123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  var json = pm.response.json();",
                  "  if (json && json.token) {",
                  "    pm.environment.set('token', json.token);",
                  "    console.log('Saved token to environment');",
                  "  }",
                  "} catch (e) { console.log('No JSON response'); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Me (protected)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api","auth","me"] }
          }
        }
      ]
    },
    {
      "name": "Favorites",
      "item": [
        {
          "name": "List favorites",
          "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/auth/favorites", "host": ["{{baseUrl}}"], "path": ["api","auth","favorites"] } }
        },
        {
          "name": "Add favorite",
          "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/auth/favorites/:cafeId", "host": ["{{baseUrl}}"], "path": ["api","auth","favorites",":cafeId"] }, "description": "Replace :cafeId in URL with actual id" }
        },
        {
          "name": "Remove favorite",
          "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/auth/favorites/:cafeId", "host": ["{{baseUrl}}"], "path": ["api","auth","favorites",":cafeId"] }, "description": "Replace :cafeId in URL with actual id" }
        }
      ]
    },
    {
      "name": "Users (admin)",
      "item": [
        {
          "name": "List users",
          "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/auth/users", "host": ["{{baseUrl}}"], "path": ["api","auth","users"] }, "description": "Requires admin token" }
        }
      ]
    },
    {
      "name": "Cafes",
      "item": [
        {
          "name": "List cafes",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/cafes?q=espresso&minRating=4&fastWifi=true", "host": ["{{baseUrl}}"], "path": ["api","cafes"], "query": [ { "key": "q", "value": "espresso" }, { "key": "minRating", "value": "4" }, { "key": "fastWifi", "value": "true" } ] } }
        },
        {
          "name": "Recommend",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/cafes/recommend?prefs={\"fastWifi\":true}", "host": ["{{baseUrl}}"], "path": ["api","cafes","recommend"] }, "description": "Query param prefs as JSON string" }
        },
        {
          "name": "Get cafe by id",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/cafes/:id", "host": ["{{baseUrl}}"], "path": ["api","cafes",":id"] }, "description": "Replace :id with cafe id" }
        },
        {
          "name": "Create cafe (admin)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"New Cafe\",\n  \"description\": \"Modern spot\",\n  \"priceLevel\": 3,\n  \"tags\": [\"Study-friendly\"],\n  \"wifiSpeed\": 30\n}" },
            "url": { "raw": "{{baseUrl}}/api/cafes", "host": ["{{baseUrl}}"], "path": ["api","cafes"] }
          }
        },
        {
          "name": "Update cafe (admin)",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"priceLevel\": 1\n}" },
            "url": { "raw": "{{baseUrl}}/api/cafes/:id", "host": ["{{baseUrl}}"], "path": ["api","cafes",":id"] }
          }
        },
        {
          "name": "Delete cafe (admin)",
          "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/cafes/:id", "host": ["{{baseUrl}}"], "path": ["api","cafes",":id"] } }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Add review (protected)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"cafeId\": 5,\n  \"rating\": 5,\n  \"text\": \"Excellent coffee.\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/reviews", "host": ["{{baseUrl}}"], "path": ["api","reviews"] }
          }
        },
        {
          "name": "Get reviews for cafe",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/reviews/cafe/:cafeId", "host": ["{{baseUrl}}"], "path": ["api","reviews","cafe",":cafeId"] }, "description": "Replace :cafeId" }
        },
        {
          "name": "List all reviews (admin)",
          "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/reviews", "host": ["{{baseUrl}}"], "path": ["api","reviews"] }, "description": "Requires admin" }
        },
        {
          "name": "Delete review (admin)",
          "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/reviews/:id", "host": ["{{baseUrl}}"], "path": ["api","reviews",":id"] } }
        }
      ]
    },
    {
      "name": "Google",
      "item": [
        {
          "name": "Get photo proxy",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/google/photo", "host": ["{{baseUrl}}"], "path": ["api","google","photo"] } }
        }
      ]
    }
  ]
}
