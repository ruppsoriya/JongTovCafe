# Example environment variables for the backend (no secrets)
# Copy this file to `.env` and fill with real values for local development.

# Server port
PORT=5000

# MongoDB connection string (for local development)
# Example: mongodb://localhost:27017/caferecs
MONGO_URI=mongodb://localhost:27017/caferecs

# JWT secret used to sign auth tokens (generate a secure random string)
JWT_SECRET=your_jwt_secret_here

# Optional: Google Places API key (enables /api/google/photo)
# GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Optional (for Postgres deployments):
# DATABASE_URL=postgres://user:password@hostname:5432/dbname
# DB_SSL=false
