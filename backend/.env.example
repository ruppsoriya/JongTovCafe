# Example environment variables for backend
# Use a real Postgres DATABASE_URL in production. If omitted, the app will use local SQLite.

# Postgres connection string (optional for production)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# JWT secret used to sign auth tokens (generate a secure random string)
# JWT_SECRET=your_jwt_secret_here

# If your Postgres provider requires SSL set to true
# DB_SSL=true

# Google Places API key (optional - enables /api/google/photo)
# GOOGLE_PLACES_API_KEY=your_google_places_key_here

# Port the server listens on (optional)
# PORT=5000
PORT=5000
DATABASE_URL=postgres://user:password@hostname:5432/dbname
DB_SSL=false
JWT_SECRET=your_jwt_secret_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key
PORT=5000
MONGO_URI=mongodb://localhost:27017/caferecs
JWT_SECRET=your_jwt_secret_here
