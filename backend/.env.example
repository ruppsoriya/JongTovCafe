# Example environment variables for the backend (no secrets)
# Copy this file to `.env` and fill with real values for local development.

PORT=5000
JWT_SECRET=your_jwt_secret_here

# Optional: use Postgres for deployment or direct local testing.
# If DATABASE_URL is omitted, the app falls back to SQLite.
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname
# DB_SSL=true

# Set to true when running inside Docker Compose with the local postgres service.
# RUNNING_IN_DOCKER=true
